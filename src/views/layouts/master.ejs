<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="UTF-8" />

    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="description" content="AICA WhatsApp Gateway Enterprise" />

    <meta name="author" content="PT AICA INDRIA" />

    <meta name="theme-color" content="#16a34a" />

    <title>
      <%= typeof title !== 'undefined' ? title : 'AICA WhatsApp Gateway
      Enterprise' %>
    </title>

    <!-- =======================================================
         Google Font
    ======================================================== -->

    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- =======================================================
         Bootstrap
    ======================================================== -->

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- =======================================================
         Bootstrap Icon
    ======================================================== -->

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
      rel="stylesheet"
    />

    <!-- =======================================================
         Animate CSS
    ======================================================== -->

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"
    />

    <!-- =======================================================
         SweetAlert2
    ======================================================== -->

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css"
    />

    <!-- =======================================================
         NProgress
    ======================================================== -->

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.css"
    />

    <!-- =======================================================
         Application CSS
    ======================================================== -->

    <link rel="stylesheet" href="/css/app.css" />

    <link rel="stylesheet" href="/css/sidebar.css" />

    <link rel="stylesheet" href="/css/navbar.css" />

    <link rel="stylesheet" href="/css/dashboard.css" />
  </head>

  <body>
    <div id="loader">
      <div class="loader-wrapper">
        <div class="spinner-border text-success" role="status">
          <span class="visually-hidden"> Loading... </span>
        </div>

        <h5 class="mt-3">Starting Gateway...</h5>
      </div>
    </div>

    <div id="app">
      <!-- ==========================================
         Sidebar
    =========================================== -->

      <aside id="sidebar"><%- include('../partials/sidebar') %></aside>

      <!-- ==========================================
         Main
    =========================================== -->

      <main id="main-wrapper">
        <!-- Navbar -->

        <%- include('../partials/navbar') %>

        <!-- Page -->

        <section class="page-content">
          <div class="container-fluid py-4"><%- body %></div>
        </section>

        <!-- Footer -->

        <%- include('../partials/footer') %>
      </main>
    </div>

    <!-- ======================================================
     GLOBAL TOAST
======================================================= -->

    <div class="toast-container position-fixed top-0 end-0 p-3 z-3">
      <div
        id="liveToast"
        class="toast border-0 shadow"
        role="alert"
        aria-live="assertive"
        aria-atomic="true"
      >
        <div class="toast-header">
          <i class="bi bi-whatsapp text-success me-2"></i>

          <strong class="me-auto"> AICA Gateway </strong>

          <small> now </small>

          <button
            type="button"
            class="btn-close"
            data-bs-dismiss="toast"
          ></button>
        </div>

        <div class="toast-body" id="toastMessage">Notification</div>
      </div>
    </div>

    <!-- ======================================================
     GLOBAL LOADING
======================================================= -->

    <div id="global-loading" class="d-none">
      <div class="loading-backdrop">
        <div class="text-center">
          <div class="spinner-border text-success" role="status"></div>

          <div class="mt-3">Please Wait...</div>
        </div>
      </div>
    </div>

    <!-- ======================================================
     QR MODAL
======================================================= -->

    <div class="modal fade" id="qrModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5>WhatsApp QR Code</h5>

            <button class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <div class="modal-body text-center">
            <img
              id="qrImage"
              src=""
              class="img-fluid"
              style="max-width: 300px"
            />

            <p class="mt-3 text-muted">Scan menggunakan Linked Device</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ======================================================
     IMAGE PREVIEW
======================================================= -->

    <div class="modal fade" id="imageModal" tabindex="-1">
      <div class="modal-dialog modal-xl">
        <div class="modal-content">
          <div class="modal-header">
            <h5>Preview</h5>

            <button class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <div class="modal-body text-center">
            <img id="previewImage" class="img-fluid" />
          </div>
        </div>
      </div>
    </div>

    <!-- ======================================================
     CONFIRM MODAL
======================================================= -->

    <div class="modal fade" id="confirmModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5>Confirmation</h5>
          </div>

          <div class="modal-body">
            <p id="confirmText">Are you sure?</p>
          </div>

          <div class="modal-footer">
            <button class="btn btn-secondary" data-bs-dismiss="modal">
              Cancel
            </button>

            <button class="btn btn-danger" id="confirmButton">Yes</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ======================================================
     RIGHT NOTIFICATION PANEL
======================================================= -->

    <div id="notification-panel" class="notification-panel">
      <div class="notification-header">
        <h5>Notifications</h5>

        <button class="btn-close" id="closeNotification"></button>
      </div>

      <div id="notification-content" class="notification-content">
        <div class="text-center text-muted py-5">No Notification</div>
      </div>
    </div>

    <!-- ======================================================
     FLOATING STATUS
======================================================= -->

    <div id="gateway-status" class="gateway-floating">
      <div class="status-circle bg-success"></div>

      <div>
        <div>Gateway Connected</div>

        <small id="gateway-status-text"> Realtime Monitoring </small>
      </div>
    </div>

    <!-- ======================================================
     BACK TO TOP
======================================================= -->

    <button id="backToTop" class="btn btn-success">
      <i class="bi bi-arrow-up"> </i>
    </button>

    <!-- =======================================================
     Bootstrap
======================================================= -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- =======================================================
     Axios
======================================================= -->

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <!-- =======================================================
     Socket.IO
======================================================= -->

    <script src="/socket.io/socket.io.js"></script>

    <!-- =======================================================
     SweetAlert2
======================================================= -->

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- =======================================================
     ChartJS
======================================================= -->

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- =======================================================
     MomentJS
======================================================= -->

    <script src="https://cdn.jsdelivr.net/npm/moment@2.30.1/min/moment.min.js"></script>

    <!-- =======================================================
     NProgress
======================================================= -->

    <script src="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.js"></script>

    <script>
      window.GATEWAY = {
        APP_NAME: "AICA WhatsApp Gateway",

        VERSION: "5.0.0",

        SOCKET: io(),

        BASE_URL: window.location.origin,
      };
    </script>

    <script>
      const socket = GATEWAY.SOCKET;

      let gatewayHealth = {};

      let toast;

      document.addEventListener("DOMContentLoaded", () => {
        toast = new bootstrap.Toast(document.getElementById("liveToast"));
      });
    </script>

    <script>
      function showLoading() {
        document

          .getElementById("global-loading")

          .classList.remove("d-none");
      }

      function hideLoading() {
        document

          .getElementById("global-loading")

          .classList.add("d-none");
      }
    </script>

    <script>
      function toastSuccess(message) {
        document.getElementById("toastMessage").innerHTML = message;

        toast.show();
      }
    </script>

    <script>
      function toastError(message) {
        Swal.fire({
          icon: "error",

          title: "Gateway",

          text: message,
        });
      }
    </script>

    <script>
      function confirmDialog(
        title,

        text,

        callback,
      ) {
        Swal.fire({
          title,

          text,

          icon: "warning",

          showCancelButton: true,

          confirmButtonText: "Yes",

          cancelButtonText: "Cancel",
        }).then((result) => {
          if (result.isConfirmed) {
            callback();
          }
        });
      }
    </script>

    <script>
      function formatBytes(bytes) {
        if (bytes === 0) return "0";

        const k = 1024;

        const sizes = ["B", "KB", "MB", "GB"];

        const i = Math.floor(Math.log(bytes) / Math.log(k));

        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + " " + sizes[i];
      }
    </script>

    <script>
      function updateRealtimeClock() {
        const el = document.getElementById("current-time");

        if (!el) return;

        el.innerHTML = moment().format("DD MMM YYYY HH:mm:ss");
      }

      setInterval(
        updateRealtimeClock,

        1000,
      );
    </script>

    <script>
      function toggleDarkMode() {
        const html = document.documentElement;

        const mode = html.getAttribute("data-bs-theme");

        html.setAttribute(
          "data-bs-theme",

          mode === "light" ? "dark" : "light",
        );
      }
    </script>

    <!-- =======================================================
     SOCKET EVENT
======================================================= -->

    <script>
      socket.on("connect", () => {
        console.log("Socket Connected");

        toastSuccess("Realtime Connected");
      });

      socket.on("disconnect", () => {
        console.log("Socket Disconnected");

        toastError("Realtime Disconnected");
      });
    </script>

    <!-- =======================================================
     HEALTH UPDATE
======================================================= -->

    <script>
      socket.on(
        "health",

        function (data) {
          gatewayHealth = data;

          updateGatewayStatus(data);
        },
      );
    </script>

    <!-- =======================================================
     UPDATE STATUS
======================================================= -->

    <script>
      function updateGatewayStatus(data) {
        const badge = document.getElementById("gateway-status");

        if (!badge) return;

        if (data.whatsapp.ready) {
          badge.classList.remove("offline");

          badge.classList.add("online");
        } else {
          badge.classList.remove("online");

          badge.classList.add("offline");
        }
      }
    </script>

    <!-- =======================================================
     LIVE LOG
======================================================= -->

    <script>
      function appendLog(message, type = "info") {
        const panel = document.getElementById("live-log");

        if (!panel) return;

        const div = document.createElement("div");

        div.className = "log-item " + type;

        div.innerHTML = "[" + moment().format("HH:mm:ss") + "] " + message;

        panel.prepend(div);

        if (panel.children.length > 300) {
          panel.removeChild(panel.lastChild);
        }
      }
    </script>

    <!-- =======================================================
     CHART HELPER
======================================================= -->

    <script>
      window.gatewayChart = null;

      function initChart() {
        const canvas = document.getElementById("gatewayChart");

        if (!canvas) return;

        gatewayChart = new Chart(
          canvas,

          {
            type: "line",

            data: {
              labels: [],

              datasets: [
                {
                  label: "Message",

                  data: [],

                  borderWidth: 2,

                  tension: 0.4,
                },
              ],
            },

            options: {
              responsive: true,

              maintainAspectRatio: false,
            },
          },
        );
      }
    </script>

    <!-- =======================================================
     ACTIVE SIDEBAR
======================================================= -->

    <script>
      (function () {
        const links = document.querySelectorAll(".sidebar-menu a");

        links.forEach(function (a) {
          if (a.href === window.location.href) {
            a.classList.add("active");
          }
        });
      })();
    </script>

    <!-- ==============================================BACK TO TOP====================================================== -->
    <script>
      const topButton = document.getElementById("backToTop");

      window.addEventListener(
        "scroll",

        function () {
          if (window.scrollY > 200) {
            topButton.style.display = "block";
          } else {
            topButton.style.display = "none";
          }
        },
      );

      topButton.addEventListener(
        "click",

        function () {
          window.scrollTo({
            top: 0,

            behavior: "smooth",
          });
        },
      );
    </script>

    <!-- ===============================================LOADER====================================================== -->

    <script>
      window.addEventListener(
        "load",

        function () {
          setTimeout(function () {
            document.getElementById("loader").style.display = "none";
          }, 700);
        },
      );
    </script>

    <!-- ============================================NPROGRESS====================================================== -->

    <script>
      NProgress.configure({
        showSpinner: false,
      });

      document.addEventListener(
        "readystatechange",

        function () {
          if (document.readyState === "loading") {
            NProgress.start();
          }

          if (document.readyState === "complete") {
            NProgress.done();
          }
        },
      );
    </script>

    <!-- ==============================================GLOBAL AXIOS====================================================== -->

    <script>
      axios.defaults.timeout = 30000;

      axios.defaults.headers.common["X-Requested-With"] = "XMLHttpRequest";
    </script>

    <!-- =======================================================
     PAGE SCRIPT
======================================================= -->

