    <script>
      socket.on("connect", () => {
        console.log("Socket Connected");

        toastSuccess("Realtime Connected");
      });

      socket.on("disconnect", () => {
        console.log("Socket Disconnected");

        toastError("Realtime Disconnected");
      });
    </script>

    <!-- =======================================================
     HEALTH UPDATE
======================================================= -->

    <script>
      socket.on(
        "health",

        function (data) {
          gatewayHealth = data;

          updateGatewayStatus(data);
        },
      );
    </script>

    <!-- =======================================================
     UPDATE STATUS
======================================================= -->

    <script>
      function updateGatewayStatus(data) {
        const badge = document.getElementById("gateway-status");

        if (!badge) return;

        if (data.whatsapp.ready) {
          badge.classList.remove("offline");

          badge.classList.add("online");
        } else {
          badge.classList.remove("online");

          badge.classList.add("offline");
        }
      }
    </script>

    <!-- =======================================================
     LIVE LOG
======================================================= -->

    <script>
      function appendLog(message, type = "info") {
        const panel = document.getElementById("live-log");

        if (!panel) return;

        const div = document.createElement("div");

        div.className = "log-item " + type;

        div.innerHTML = "[" + moment().format("HH:mm:ss") + "] " + message;

        panel.prepend(div);

        if (panel.children.length > 300) {
          panel.removeChild(panel.lastChild);
        }
      }
    </script>

    <!-- =======================================================
     CHART HELPER
======================================================= -->

    <script>
      window.gatewayChart = null;

      function initChart() {
        const canvas = document.getElementById("gatewayChart");

        if (!canvas) return;

        gatewayChart = new Chart(
          canvas,

          {
            type: "line",

            data: {
              labels: [],

              datasets: [
                {
                  label: "Message",

                  data: [],

                  borderWidth: 2,

                  tension: 0.4,
                },
              ],
            },

            options: {
              responsive: true,

              maintainAspectRatio: false,
            },
          },
        );
      }
    </script>

    <!-- =======================================================
     ACTIVE SIDEBAR
======================================================= -->

    <script>
      (function () {
        const links = document.querySelectorAll(".sidebar-menu a");

        links.forEach(function (a) {
          if (a.href === window.location.href) {
            a.classList.add("active");
          }
        });
      })();
    </script>

    <!-- ==============================================BACK TO TOP====================================================== -->
    <script>
      const topButton = document.getElementById("backToTop");

      window.addEventListener(
        "scroll",

        function () {
          if (window.scrollY > 200) {
            topButton.style.display = "block";
          } else {
            topButton.style.display = "none";
          }
        },
      );

      topButton.addEventListener(
        "click",

        function () {
          window.scrollTo({
            top: 0,

            behavior: "smooth",
          });
        },
      );
    </script>

    <!-- ===============================================LOADER====================================================== -->

    <script>
      window.addEventListener(
        "load",

        function () {
          setTimeout(function () {
            document.getElementById("loader").style.display = "none";
          }, 700);
        },
      );
    </script>

    <!-- ============================================NPROGRESS====================================================== -->

    <script>
      NProgress.configure({
        showSpinner: false,
      });

      document.addEventListener(
        "readystatechange",

        function () {
          if (document.readyState === "loading") {
            NProgress.start();
          }

          if (document.readyState === "complete") {
            NProgress.done();
          }
        },
      );
    </script>

    <!-- ==============================================GLOBAL AXIOS====================================================== -->

    <script>
      axios.defaults.timeout = 30000;

      axios.defaults.headers.common["X-Requested-With"] = "XMLHttpRequest";
    </script>

    <!-- =======================================================
     PAGE SCRIPT
======================================================= -->
<% if (script) { %>

<script src="<%= script %>"></script>

<% } %>

  </body>
</html>
