<div class="row g-4">
  <div class="col-12">
    <div class="dashboard-hero p-4">
      <div
        class="d-flex justify-content-between align-items-start flex-wrap gap-3"
      >
        <div>
          <h2 class="mb-1 fw-bold">Dashboard</h2>
          <p class="mb-0 text-muted">AICA WhatsApp Gateway Enterprise</p>
        </div>
        <div class="d-flex gap-2">
          <button class="btn btn-outline-warning btn-sm" id="btnReconnect">
            <i class="bi bi-arrow-repeat me-1"></i>Reconnect
          </button>
          <button class="btn btn-outline-danger btn-sm" id="btnRestart">
            <i class="bi bi-bootstrap-reboot me-1"></i>Restart
          </button>
          <button class="btn btn-outline-secondary btn-sm" id="btnLogout">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-label">Status</div>
      <div class="stat-value" id="wa-status"><%= health.whatsapp.status %></div>
      <div class="stat-meta">
        <span class="status-dot bg-success"></span
        ><span id="wa-status-text"
          ><%= health.whatsapp.ready ? 'Online' : 'Offline' %></span
        >
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-label">Phone</div>
      <div class="stat-value" id="wa-phone">
        <%= health.whatsapp.phone || '-' %>
      </div>
      <div class="stat-meta">Connected device</div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-label">Queue</div>
      <div class="stat-value" id="queue-waiting">
        <%= health.queue.waiting %>
      </div>
      <div class="stat-meta">Waiting to send</div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-label">Memory</div>
      <div class="stat-value" id="memory-rss"><%= health.memory.rss %></div>
      <div class="stat-meta">Process RSS</div>
    </div>
  </div>

  <div class="col-xl-8">
    <div class="panel-card">
      <div class="panel-header">
        <h5 class="mb-0">Gateway Analytics</h5>
        <small class="text-muted">Realtime message activity</small>
      </div>
      <div class="panel-body">
        <canvas id="gatewayChart" height="120"></canvas>
      </div>
    </div>
  </div>

  <div class="col-xl-4">
    <div class="panel-card h-100">
      <div class="panel-header">
        <h5 class="mb-0">Gateway Info</h5>
        <small class="text-muted">Runtime details</small>
      </div>
      <div class="panel-body">
        <ul class="info-list">
          <li>
            <span>Gateway</span><strong><%= health.gateway.name %></strong>
          </li>
          <li>
            <span>Version</span><strong><%= health.gateway.version %></strong>
          </li>
          <li><span>Node</span><strong><%= health.gateway.node %></strong></li>
          <li>
            <span>Uptime</span
            ><strong id="uptime"><%= health.uptime.formatted %></strong>
          </li>
          <li><span>CPU</span><strong><%= health.cpu.cores %> Core</strong></li>
          <li>
            <span>Platform</span><strong><%= health.system.platform %></strong>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-xl-6">
    <div class="panel-card h-100">
      <div class="panel-header">
        <h5 class="mb-0">Live Log</h5>

        <small class="text-muted"> Realtime gateway events </small>
      </div>
      <div class="panel-body">
        <div id="live-log" class="live-log">
          <div class="text-muted">Waiting for events...</div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-6">
    <div class="panel-card h-100">
      <div class="panel-header">
        <h5 class="mb-0">Quick Actions</h5>

        <small class="text-muted"> Gateway Control </small>
      </div>

      <div class="panel-body">
        <!-- QR CARD -->

        <div class="panel-card mb-4">
          <div class="panel-header">
            <h5 class="mb-0">QR Code</h5>
          </div>

          <div class="panel-body text-center">
            <div
              id="qr-panel"
              class="d-flex justify-content-center align-items-center"
              style="min-height: 260px"
            >
              <span class="text-muted"> QR belum tersedia </span>
            </div>
          </div>
        </div>

        <!-- BUTTON -->

        <div class="d-grid gap-2">
          <button class="btn btn-success" id="btnStartGateway">
            <i class="bi bi-play-fill"></i>

            Start Gateway
          </button>

          <button class="btn btn-danger" id="btnStopGateway">
            <i class="bi bi-stop-fill"></i>

            Stop Gateway
          </button>

          <button class="btn btn-warning" id="btnRestartGateway">
            Restart Gateway
          </button>

          <button class="btn btn-secondary" id="btnLogoutGateway">
            Logout Device
          </button>

          <button class="btn btn-primary" id="btnBackup">Backup Session</button>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12">
    <div class="panel-card mt-4">
      <div class="panel-header">
        <h5 class="mb-0">
          <i class="bi bi-chat-dots me-2"></i>
          Message History
        </h5>

        <small class="text-muted"> Last 50 WhatsApp Messages </small>
      </div>

      <div class="panel-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>Time</th>

                <th>Phone</th>

                <th>Message</th>

                <th>Status</th>

                <th>ACK</th>

                <th>Retry</th>

                <th>Action</th>
              </tr>
            </thead>

            <tbody id="historyBody">
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  No Message
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
