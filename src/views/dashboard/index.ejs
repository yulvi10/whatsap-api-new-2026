<% layout('layouts/master', { title: 'Dashboard - AICA WhatsApp Gateway Enterprise' }) %>

<div class="row g-4">

  <div class="col-12">
    <div class="page-header">
      <div>
        <h1 class="page-title mb-1">Dashboard</h1>
        <p class="page-subtitle mb-0">AICA WhatsApp Gateway Enterprise v5</p>
      </div>

      <div class="page-actions">
        <button id="btn-reconnect" class="btn btn-outline-warning btn-sm">
          <i class="bi bi-arrow-clockwise me-1"></i>Reconnect
        </button>
        <button id="btn-restart-gateway" class="btn btn-outline-danger btn-sm">
          <i class="bi bi-bootstrap-reboot me-1"></i>Restart
        </button>
        <button id="btn-logout" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-box-arrow-right me-1"></i>Logout
        </button>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6">
    <div class="stat-card stat-connected">
      <div class="stat-label">Status</div>
      <div class="stat-value" id="wa-status"><%= health.whatsapp.status %></div>
      <div class="stat-meta">
        <span class="status-dot bg-success"></span>
        <span id="wa-status-text"><%= health.whatsapp.ready ? 'Online' : 'Offline' %></span>
      </div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-label">Phone</div>
      <div class="stat-value" id="wa-phone"><%= health.whatsapp.phone || '-' %></div>
      <div class="stat-meta">Connected device number</div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-label">Queue</div>
      <div class="stat-value" id="queue-waiting"><%= health.queue.waiting %></div>
      <div class="stat-meta">Waiting to send</div>
    </div>
  </div>

  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-label">Memory</div>
      <div class="stat-value" id="memory-rss"><%= health.memory.rss %></div>
      <div class="stat-meta">Process RSS</div>
    </div>
  </div>

  <div class="col-xl-8">
    <div class="card dashboard-panel h-100">
      <div class="card-header dashboard-panel-header">
        <div>
          <h5 class="mb-0">Gateway Analytics</h5>
          <small class="text-muted">Realtime messages per hour</small>
        </div>
      </div>
      <div class="card-body">
        <canvas id="messageChart" height="120"></canvas>
      </div>
    </div>
  </div>

  <div class="col-xl-4">
    <div class="card dashboard-panel h-100">
      <div class="card-header dashboard-panel-header">
        <div>
          <h5 class="mb-0">Gateway Info</h5>
          <small class="text-muted">Current runtime details</small>
        </div>
      </div>

      <div class="card-body">
        <ul class="info-list">
          <li><span>Gateway</span><strong><%= health.gateway.name %></strong></li>
          <li><span>Version</span><strong><%= health.gateway.version %></strong></li>
          <li><span>Node</span><strong><%= health.gateway.node %></strong></li>
          <li><span>Uptime</span><strong id="uptime"><%= health.uptime.formatted %></strong></li>
          <li><span>CPU</span><strong><%= health.cpu.cores %> Core</strong></li>
          <li><span>Platform</span><strong><%= health.system.platform %></strong></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-xl-6">
    <div class="card dashboard-panel h-100">
      <div class="card-header dashboard-panel-header">
        <div>
          <h5 class="mb-0">Live Activity</h5>
          <small class="text-muted">Latest gateway events</small>
        </div>
      </div>
      <div class="card-body">
        <div id="live-log" class="live-log">
          <div class="live-log-item text-muted">Waiting for realtime events...</div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-xl-6">
    <div class="card dashboard-panel h-100">
      <div class="card-header dashboard-panel-header">
        <div>
          <h5 class="mb-0">Quick Actions</h5>
          <small class="text-muted">Gateway control center</small>
        </div>
      </div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <button id="btn-restart" class="btn btn-danger">
            <i class="bi bi-bootstrap-reboot me-2"></i>Restart Gateway
          </button>
          <button id="btn-reconnect-2" class="btn btn-warning">
            <i class="bi bi-arrow-repeat me-2"></i>Reconnect
          </button>
          <button id="btn-generate-qr" class="btn btn-success">
            <i class="bi bi-qr-code me-2"></i>Generate QR
          </button>
          <button id="btn-backup" class="btn btn-primary">
            <i class="bi bi-cloud-arrow-down me-2"></i>Backup Session
          </button>
        </div>
      </div>
    </div>
  </div>

</div>