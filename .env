# ==========================================================
# APPLICATION
# ==========================================================

APP_NAME=AICA WhatsApp Gateway
APP_ENV=production
APP_DEBUG=false

# ==========================================================
# SERVER
# ==========================================================

HOST=0.0.0.0
PORT=8088

# ==========================================================
# API SECURITY
# ==========================================================

TOKEN=AICA123456

# ==========================================================
# WHATSAPP
# ==========================================================

SESSION_NAME=AICA_GATEWAY

HEADLESS=false

USE_CHROME=true

CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

AUTO_CLOSE=0

DEVICE_NAME=AICA Gateway

DEVICE_BROWSER=Chrome

DEVICE_PLATFORM=Windows

# ==========================================================
# QUEUE
# ==========================================================

QUEUE_DELAY=1000

MAX_RETRY=5

SEND_TIMEOUT=30000

# ==========================================================
# RECONNECT
# ==========================================================

RECONNECT_DELAY=5000

MAX_RECONNECT=999999

# ==========================================================
# LOG
# ==========================================================

LOG_LEVEL=info

# ==========================================================
# QR CODE
# ==========================================================

QR_PATH=./src/public/qr.png